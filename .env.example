# Maintenance: .env.example.md mirrors this file by hand (no generator) — update both together.

# Baseline lane — Inspect provider auth (the only auth path for comparable runs).
# ANTHROPIC_API_KEY=sk-ant-api-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# ANTHROPIC_BASE_URL=            # optional gateway / proxy endpoint

# Moonshot (Kimi K2.5 base-model row; see concept-hld / models registry).
# Moonshot exposes an OpenAI-compatible endpoint. Route via Inspect's OpenAI-compatible provider
# (scoped base_url override or a dedicated `moonshot/` model id) — confirm exact Inspect routing
# during Phase 3 prep.
# MOONSHOT_API_KEY=sk-moonshot-xxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Experimental lane (Phase 4 only; not used for baseline results).
# Claude Code gateway: ANTHROPIC_AUTH_TOKEN / apiKeyHelper live in the Claude Code config, not here.
# Codex CLI standalone auth is handled by `codex` login, not env vars.

# Phase B live pilot (see docs/ops/dev-box-pilot.md)
# ByteLLM: BYTELLM_API_KEY is treated as the authoritative proxy key and is
# mapped to ANTHROPIC_AUTH_TOKEN / OPENAI_API_KEY inside the pilot process.
# BYTELLM_API_KEY=sk-bytellm-xxxxx
# BYTELLM_BASE_URL=http://127.0.0.1:4000
# BENCHEVAL_PILOT_MODEL=gpt-5.3-codex-2026-02-24
# BENCHEVAL_PILOT_CLAUDE_MODEL=gpt-5.3-codex-2026-02-24
# BENCHEVAL_PILOT_CODEX_MODEL=gpt-5.3-codex-2026-02-24
# BENCHEVAL_PILOT_BFCL_MODEL=openai/your-model
# BENCHEVAL_PILOT_SWE_MODEL=openai/your-model
# BENCHEVAL_ALLOW_PREFLIGHT_ONLY=1
# BENCHEVAL_HARBOR_FORWARD_PROXY=1
# BENCHEVAL_ANTHROPIC_SYSTEM_ROLE_SHIM=1
# BENCHEVAL_SHIM_AUTH_TOKEN_ENV=BYTELLM_PROXY_API_KEY
# BENCHEVAL_CLAUDE_CODE_NPM_REGISTRY=https://registry.npmjs.org/
# BENCHEVAL_CLAUDE_CODE_ALLOWED_TOOLS=Bash,Read,Write
# BENCHEVAL_HOME=
# HTTP_PROXY=
# NO_PROXY=127.0.0.1,localhost

# Optional: Harbor / remote runners
# DAYTONA_API_KEY=
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
