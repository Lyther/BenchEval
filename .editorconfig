root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python: keep the editor ruler in sync with ruff (line-length = 100 in pyproject.toml).
# NOTE: advisory hint only — it does not make an editor wrap identically to ruff. The
# gate's wrapping is owned by `ruff format` (enforced by .pre-commit-config.yaml + CI).
[*.py]
max_line_length = 100

[*.{json,yml,yaml,html,css,scss,js,ts,tsx,jsx,mjs,cjs}]
indent_size = 2

[Makefile]
indent_style = tab

[go.mod]
indent_style = tab

[COMMIT_EDITMSG]
max_line_length = 72
